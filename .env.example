# Claude
ANTHROPIC_API_KEY=

# Email delivery
REPORT_EMAIL_TO=you@example.com
REPORT_EMAIL_FROM=sender@example.com
REPORT_EMAIL_SUBJECT_PREFIX=Daily Chart AI Outlook
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=sender@example.com
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_TIMEOUT_SECONDS=60

# Daily report job defaults
DAILY_REPORT_UNIVERSE=us_listed
DAILY_REPORT_OUTPUT_DIR=reports
DAILY_REPORT_HAIKU_WORKERS=
DAILY_REPORT_HAIKU_TRIAGE_LIMIT=
DAILY_REPORT_SKIP_HAIKU_CACHE=false

# Optional cap for testing only. Leave blank for production full runs.
DAILY_REPORT_MAX_UNIVERSE_SIZE=
